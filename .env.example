# ── Base de datos (Supabase provee este valor) ─────────────────────────────
# Opción 1: connection string completa (recomendada para Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Opción 2: variables sueltas (alternativa si no usa DATABASE_URL)
# DB_HOST=db.[REF].supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASS=tu-password-supabase
# DB_NAME=postgres

# ── Aplicación ────────────────────────────────────────────────────────────
# URL pública del frontend en Render (sin barra final)
FRONTEND_URL=https://tu-app.onrender.com

# Puerto que usa uvicorn (Render lo inyecta automáticamente)
PORT=8000
